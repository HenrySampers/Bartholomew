GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here  # must start with AIzaSy...

# Brain
BART_BRAIN_PROVIDERS=ollama,gemini
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=25
GEMINI_MODEL=gemini-2.5-flash
BART_BRAIN_MODE=fast
BART_CHAT_HISTORY_TURNS=12
BART_TOOL_HISTORY_TURNS=6
BART_PROFILE_MEMORY_LIMIT=6
BART_USE_PALACE_CONTEXT=true
BART_USE_PALACE_FOR_TOOLS=false

# Text-to-speech
TTS_PROVIDER=piper
PIPER_EXE=piper
PIPER_MODEL=C:\Users\hsamp\Bartholomew\models\piper\en_US-ryan-medium.onnx
PIPER_LENGTH_SCALE=1.0
PIPER_STREAM_TARGET_CHARS=110
PIPER_PLAYBACK_MARGIN=0.35
PIPER_FIRST_SENTENCE_TIMEOUT=4.5

# Speech-to-text
STT_PROVIDER=faster_whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Weather (leave blank to use IP geolocation)
WEATHER_LOCATION=New Jersey

# Spotify (get credentials at developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# UI
OVERLAY_ENABLED=true

# Wake activation
WAKE_WORD_ENABLED=false
WAKE_METHOD=openwakeword
WAKE_MODEL=hey_mycroft
WAKE_THRESHOLD=0.35
WAKE_DEBUG=false

# Double-clap activation
CLAP_THRESHOLD=3500
CLAP_MIN_GAP=0.12
CLAP_MAX_GAP=0.6
CLAP_COOLDOWN=1.5
CLAP_DYNAMIC_RATIO=3.5
CLAP_RESET_AFTER=1.0

# Follow-up recording after wake word
WAKE_FOLLOWUP_START_TIMEOUT=5
WAKE_FOLLOWUP_MAX_SECONDS=12
WAKE_FOLLOWUP_SILENCE_SECONDS=1.0
WAKE_FOLLOWUP_ENERGY_THRESHOLD=250
