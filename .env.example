GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here  # must start with AIzaSy...

# Brain
BART_BRAIN_PROVIDERS=ollama,gemini
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434
GEMINI_MODEL=gemini-2.5-flash

# Text-to-speech
TTS_PROVIDER=piper
PIPER_EXE=piper
PIPER_MODEL=C:\Users\hsamp\Bartholomew\models\piper\en_US-ryan-medium.onnx
PIPER_LENGTH_SCALE=1.0

# Speech-to-text
STT_PROVIDER=faster_whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Weather (leave blank to use IP geolocation)
WEATHER_LOCATION=New Jersey

# Spotify (get credentials at developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# UI
OVERLAY_ENABLED=true

# Wake word (default model listens for "hey mycroft")
WAKE_WORD_ENABLED=false
WAKE_MODEL=hey_mycroft
WAKE_THRESHOLD=0.5
