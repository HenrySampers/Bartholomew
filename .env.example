GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_optional_gemini_key_here

# Free-first chat brain. Ollama runs locally on your PC.
BART_BRAIN_PROVIDERS=ollama,gemini
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434

# Optional Gemini fallback model.
GEMINI_MODEL=gemini-2.5-flash

# Text-to-speech. Use pyttsx3 until Piper is installed and configured.
TTS_PROVIDER=piper
PIPER_EXE=piper
PIPER_MODEL=C:\Users\hsamp\Bartholomew\models\piper\en_GB-alan-medium.onnx
PIPER_LENGTH_SCALE=1.3

# Speech-to-text. faster_whisper runs locally; groq uses the Groq API.
STT_PROVIDER=faster_whisper
WHISPER_MODEL=medium.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
